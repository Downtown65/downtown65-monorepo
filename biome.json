{
  "$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
  "files": {
    "includes": [
      "**",
      "!.claude",
      "!.agents",
      "!.planning",
      "!**/.astro",
      "!**/*.astro",
      "!**/worker-configuration.d.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "recommended": true,
        "noNodejsModules": "off"
      },
      "complexity": {
        "noExcessiveLinesPerFunction": "off"
      },
      "suspicious": {
        "recommended": true,
        "noConsole": "error"
      },
      "style": {
        "recommended": true,
        "noDefaultExport": "off"
      },
      "performance": {
        "recommended": true,
        "useSolidForComponent": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "quoteStyle": "single"
    }
  },
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
