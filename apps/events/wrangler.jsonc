{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "downtown65-events",
  "main": "./workers/app.ts",
  "compatibility_date": "2026-02-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "env": {
    "production": {
      "name": "downtown65-events-production",
      "workers_dev": true
    }
  }
}
