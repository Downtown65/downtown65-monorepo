{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "exactOptionalPropertyTypes": false,
    "rootDir": ".",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "paths": {
      "~/*": ["./app/*"]
    },
    "types": ["vite/client"],
    "rootDirs": [".", "./.react-router/types"]
  },
  "include": [
    "app",
    "workers",
    "env.d.ts",
    "react-router.config.ts",
    "vite.config.ts",
    ".react-router/types/**/*"
  ],
  "references": [{ "path": "../../packages/shared" }]
}
