{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "downtown65-www",
  "compatibility_date": "2026-02-01",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist"
  },
  "env": {
    "production": {
      "name": "downtown65-www-production",
      "workers_dev": true
    }
  }
}
