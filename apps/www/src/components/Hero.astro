---
const stickers = [
  { src: '/images/stickers/skull.png', alt: 'DT65 skull', class: 'top-[12%] left-[15%] w-24 rotate-[-15deg] sm:w-30 md:w-36' },
  { src: '/images/stickers/dt65-front.png', alt: 'DT65 t-shirt front', class: 'top-[8%] right-[18%] w-22 rotate-[9deg] sm:w-28 md:w-34' },
  { src: '/images/stickers/dt65-sticker.png', alt: 'Downtown 65 logo', class: 'top-[38%] left-[10%] w-28 rotate-[-5deg] sm:w-34 md:w-40' },
  { src: '/images/stickers/logo.png', alt: 'Downtown 65 oval logo', class: 'top-[42%] right-[12%] w-26 rotate-[14deg] sm:w-32 md:w-38' },
  { src: '/images/stickers/palkkapäivä.png', alt: 'Palkkapäivä skeleton', class: 'bottom-[12%] left-[20%] w-26 rotate-[4deg] sm:w-32 md:w-38' },
  { src: '/images/stickers/dt65-back.png', alt: 'DT65 t-shirt back', class: 'bottom-[15%] right-[16%] w-22 rotate-[-10deg] sm:w-28 md:w-34' },
];
---

<section class="grid-background relative flex min-h-screen items-center justify-center overflow-hidden px-4">
  {stickers.map((s) => (
    <img
      src={s.src}
      alt={s.alt}
      loading="lazy"
      class={`pointer-events-none absolute z-20 hidden opacity-80 transition-opacity duration-500 md:block ${s.class}`}
    />
  ))}

  <div class="relative z-10 text-center">
    <h1
      class="font-display text-primary-pink text-2xl leading-relaxed tracking-wider sm:text-3xl md:text-4xl lg:text-5xl"
    >
      Downtown 65
    </h1>
    <p
      class="font-display mt-6 text-xs tracking-widest text-text-secondary sm:text-sm md:text-base"
    >
      Endurance ry
    </p>
  </div>

  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-surface opacity-80"
  >
  </div>
</section>
