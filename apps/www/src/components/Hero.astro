---
const sizes = "sm:w-32 md:w-48 w-24";

const stickers = [
  // --- Top zone: row 1 (3 stickers) ---
  {
    src: "/images/stickers/skull.png",
    class: `top-[3%] left-[4%] w-16 rotate-[-15deg] ${sizes}`,
  },
  {
    src: "/images/stickers/niko-65.png",
    class: `top-[25%] left-[38%] w-14 rotate-[5deg] ${sizes}`,
  },
  {
    src: "/images/stickers/palkkapäivä.png",
    class: `top-[4%] right-[4%] w-16 rotate-[8deg] ${sizes}`,
  },
  // --- Top zone: row 2 (2 stickers, offset) ---
  {
    src: "/images/stickers/t-shirt-front.png",
    class: `top-[16%] left-[20%] w-14 rotate-[9deg] ${sizes}`,
  },
  {
    src: "/images/stickers/logo.png",
    class: `top-[8%] right-[28%] w-16 rotate-[14deg] ${sizes}`,
  },
  // --- Bottom zone: row 1 (2 stickers, offset) ---
  {
    src: "/images/stickers/sticker.png",
    class: `bottom-[25%] left-[18%] w-16 rotate-[-5deg] ${sizes}`,
  },
  {
    src: "/images/stickers/bicycle.png",
    class: `bottom-[20%] right-[16%] w-16 rotate-[6deg] ${sizes}`,
  },
  // --- Bottom zone: row 2 (3 stickers) ---
  {
    src: "/images/stickers/fuck-the-hill.png",
    class: `bottom-[3%] left-[4%] w-14 rotate-[-8deg] ${sizes}`,
  },
  {
    src: "/images/stickers/aakoo.png",
    class: `bottom-[2%] left-[36%] w-16 rotate-[8deg] ${sizes}`,
  },
  {
    src: "/images/stickers/t-shirt-back.png",
    class: `bottom-[4%] right-[4%] w-14 rotate-[-10deg] ${sizes}`,
  },
];
---

<section
  class="grid-background relative flex min-h-screen items-center justify-center overflow-hidden px-4"
>
  {
    stickers.map((s) => (
      <img
        src={s.src}
        aria-hidden="true"
        loading="lazy"
        class={`pointer-events-none absolute z-20 opacity-80 transition-opacity duration-500 ${s.class}`}
      />
    ))
  }

  <div class="relative z-10 text-center">
    <h1
      class="text-primary-pink leading-relaxed tracking-wider"
      style="font-family: 'Bangers', cursive; font-size: var(--hero-title-size);"
    >
      Downtown 65
    </h1>
    <p
      class="font-display mt-6 tracking-widest text-text-secondary"
      style="font-size: var(--hero-subtitle-size);"
    >
      Endurance ry
    </p>
  </div>

  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-surface opacity-80"
  >
  </div>
</section>
