---
const stickers = [
  // --- Top zone: row 1 (3 stickers) ---
  {
    src: "/images/stickers/skull.png",
    alt: "DT65 skull",
    class:
      "top-[3%] left-[4%] w-16 rotate-[-15deg] sm:w-24 md:w-32",
  },
  {
    src: "/images/stickers/nico-sticker.png",
    alt: "Nico sticker",
    class:
      "top-[2%] left-[38%] w-14 rotate-[5deg] sm:w-22 md:w-28",
  },
  {
    src: "/images/stickers/palkkapäivä.png",
    alt: "Palkkapäivä skeleton",
    class:
      "top-[4%] right-[4%] w-16 rotate-[8deg] sm:w-24 md:w-32",
  },
  // --- Top zone: row 2 (2 stickers, offset) ---
  {
    src: "/images/stickers/dt65-front.png",
    alt: "DT65 t-shirt front",
    class:
      "top-[16%] left-[20%] w-14 rotate-[9deg] sm:w-22 md:w-28",
  },
  {
    src: "/images/stickers/logo.png",
    alt: "Downtown 65 oval logo",
    class:
      "top-[15%] right-[18%] w-16 rotate-[14deg] sm:w-24 md:w-32",
  },
  // --- Bottom zone: row 1 (2 stickers, offset) ---
  {
    src: "/images/stickers/dt65-sticker.png",
    alt: "Downtown 65 logo",
    class:
      "bottom-[16%] left-[18%] w-16 rotate-[-5deg] sm:w-24 md:w-32",
  },
  {
    src: "/images/stickers/fiilari-sticker.png",
    alt: "Skeleton cyclist",
    class:
      "bottom-[15%] right-[16%] w-16 rotate-[6deg] sm:w-24 md:w-32",
  },
  // --- Bottom zone: row 2 (3 stickers) ---
  {
    src: "/images/stickers/fth-sticker.png",
    alt: "Fuck The Hill",
    class:
      "bottom-[3%] left-[4%] w-14 rotate-[-8deg] sm:w-22 md:w-28",
  },
  {
    src: "/images/stickers/aakoo-sticker.png",
    alt: "Aakoo headlamp runner",
    class:
      "bottom-[2%] left-[36%] w-16 rotate-[8deg] sm:w-24 md:w-32",
  },
  {
    src: "/images/stickers/dt65-back.png",
    alt: "DT65 t-shirt back",
    class:
      "bottom-[4%] right-[4%] w-14 rotate-[-10deg] sm:w-22 md:w-28",
  },
];
---

<section
  class="grid-background relative flex min-h-screen items-center justify-center overflow-hidden px-4"
>
  {
    stickers.map((s) => (
      <img
        src={s.src}
        alt=""
        aria-hidden="true"
        loading="lazy"
        class={`pointer-events-none absolute z-20 opacity-80 transition-opacity duration-500 ${s.class}`}
      />
    ))
  }

  <div class="relative z-10 text-center">
    <h1
      class="text-primary-pink leading-relaxed tracking-wider"
      style="font-family: 'Bangers', cursive; font-size: var(--hero-title-size);"
    >
      Downtown 65
    </h1>
    <p
      class="font-display mt-6 tracking-widest text-text-secondary"
      style="font-size: var(--hero-subtitle-size);"
    >
      Endurance ry
    </p>
  </div>

  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-surface opacity-80"
  >
  </div>
</section>
