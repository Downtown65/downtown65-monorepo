---
import { boardMembers } from '../data/board-members';
---

<section class="bg-surface px-4 py-20 sm:py-28">
  <div class="mx-auto max-w-5xl">
    <h2
      class="mb-16 text-center text-2xl font-bold text-primary-pink sm:text-3xl"
    >
      Hallitus
    </h2>
    <div
      class="grid grid-cols-1 justify-items-center gap-10 sm:grid-cols-2 md:gap-14 lg:grid-cols-3"
    >
      {
        boardMembers.map((member) => (
          <div class="group flex flex-col items-center">
            <div
              class="sticker mb-4 h-44 w-44 overflow-hidden bg-surface-card transition-transform duration-300 group-hover:scale-105 sm:h-52 sm:w-52"
              style={`transform: rotate(${member.rotation})`}
            >
              <img
                src={member.photoPath}
                alt={member.nickname}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
            <span class="text-lg font-bold text-text-primary">
              {member.nickname}
            </span>
            <span class="mt-1 text-sm text-text-secondary">{member.title}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
