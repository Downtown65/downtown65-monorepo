{
  "openapi": "3.1.0",
  "info": {
    "title": "DT65 API",
    "version": "1.0.0"
  },
  "security": [
    {
      "apiKey": []
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      },
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://dev-dt65.eu.auth0.com/authorize?audience=https://api.staging.downtown65.com",
            "tokenUrl": "https://dev-dt65.eu.auth0.com/oauth/token",
            "scopes": {}
          }
        }
      }
    },
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "expiresIn": {
            "type": "number"
          },
          "user": {
            "type": "object",
            "properties": {
              "sub": {
                "type": "string"
              },
              "nickname": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              },
              "picture": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": ["sub", "nickname", "name", "email", "picture"]
          }
        },
        "required": ["accessToken", "expiresIn", "user"]
      },
      "AuthError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "required": ["code", "message"]
          }
        },
        "required": ["error"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["email", "password"]
      },
      "SignupRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "nickname": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["email", "password", "name", "nickname"]
      },
      "ForgotPasswordRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          }
        },
        "required": ["email"]
      },
      "RefreshResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "expiresIn": {
            "type": "number"
          }
        },
        "required": ["accessToken", "expiresIn"]
      },
      "RefreshTokenRequest": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["refreshToken"]
      },
      "LogoutUrlResponse": {
        "type": "object",
        "properties": {
          "logoutUrl": {
            "type": "string"
          }
        },
        "required": ["logoutUrl"]
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "nickname": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "picture": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "subscribeEventCreationEmail": {
            "type": "boolean"
          },
          "subscribeWeeklyEmail": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "nickname",
          "email",
          "picture",
          "createdAt",
          "subscribeEventCreationEmail",
          "subscribeWeeklyEmail"
        ]
      },
      "EventDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "type": {
            "type": "string",
            "enum": [
              "CYCLING",
              "KARONKKA",
              "MEETING",
              "NORDIC_WALKING",
              "ICE_HOCKEY",
              "ORIENTEERING",
              "OTHER",
              "RUNNING",
              "SKIING",
              "SPINNING",
              "SWIMMING",
              "TRACK_RUNNING",
              "TRAIL_RUNNING",
              "TRIATHLON",
              "ULTRAS"
            ],
            "example": "RUNNING"
          },
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": "string"
          },
          "dateStart": {
            "type": "string",
            "format": "date"
          },
          "timeStart": {
            "type": ["string", "null"]
          },
          "location": {
            "type": "string"
          },
          "race": {
            "type": "boolean"
          },
          "description": {
            "type": ["string", "null"]
          },
          "creator": {
            "$ref": "#/components/schemas/Creator"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          },
          "participants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Participant"
            }
          }
        },
        "required": [
          "id",
          "type",
          "title",
          "subtitle",
          "dateStart",
          "timeStart",
          "location",
          "race",
          "description",
          "creator",
          "createdAt",
          "updatedAt",
          "participants"
        ]
      },
      "Creator": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "nickname": {
            "type": "string"
          }
        },
        "required": ["id", "nickname"]
      },
      "Participant": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "number"
          },
          "nickname": {
            "type": "string"
          },
          "joinedAt": {
            "type": "string"
          }
        },
        "required": ["userId", "nickname", "joinedAt"]
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "required": ["code", "message"]
          }
        },
        "required": ["error"]
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "type": {
            "type": "string",
            "enum": [
              "CYCLING",
              "KARONKKA",
              "MEETING",
              "NORDIC_WALKING",
              "ICE_HOCKEY",
              "ORIENTEERING",
              "OTHER",
              "RUNNING",
              "SKIING",
              "SPINNING",
              "SWIMMING",
              "TRACK_RUNNING",
              "TRAIL_RUNNING",
              "TRIATHLON",
              "ULTRAS"
            ],
            "example": "RUNNING"
          },
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": "string"
          },
          "dateStart": {
            "type": "string",
            "format": "date"
          },
          "timeStart": {
            "type": ["string", "null"]
          },
          "location": {
            "type": "string"
          },
          "race": {
            "type": "boolean"
          },
          "description": {
            "type": ["string", "null"]
          },
          "creatorId": {
            "type": "number"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          },
          "participantCount": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "type",
          "title",
          "subtitle",
          "dateStart",
          "timeStart",
          "location",
          "race",
          "description",
          "creatorId",
          "createdAt",
          "updatedAt",
          "participantCount"
        ]
      },
      "CreateEvent": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "CYCLING",
              "KARONKKA",
              "MEETING",
              "NORDIC_WALKING",
              "ICE_HOCKEY",
              "ORIENTEERING",
              "OTHER",
              "RUNNING",
              "SKIING",
              "SPINNING",
              "SWIMMING",
              "TRACK_RUNNING",
              "TRAIL_RUNNING",
              "TRIATHLON",
              "ULTRAS"
            ],
            "example": "RUNNING"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "dateStart": {
            "type": "string",
            "format": "date"
          },
          "timeStart": {
            "type": "string"
          },
          "location": {
            "type": "string",
            "maxLength": 200
          },
          "subtitle": {
            "type": "string",
            "maxLength": 200
          },
          "description": {
            "type": "string"
          },
          "race": {
            "type": "boolean",
            "default": false
          }
        },
        "required": ["type", "title", "dateStart", "location", "subtitle"]
      },
      "EventSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "type": {
            "type": "string",
            "enum": [
              "CYCLING",
              "KARONKKA",
              "MEETING",
              "NORDIC_WALKING",
              "ICE_HOCKEY",
              "ORIENTEERING",
              "OTHER",
              "RUNNING",
              "SKIING",
              "SPINNING",
              "SWIMMING",
              "TRACK_RUNNING",
              "TRAIL_RUNNING",
              "TRIATHLON",
              "ULTRAS"
            ],
            "example": "RUNNING"
          },
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": "string"
          },
          "dateStart": {
            "type": "string",
            "format": "date"
          },
          "timeStart": {
            "type": ["string", "null"]
          },
          "location": {
            "type": "string"
          },
          "race": {
            "type": ["boolean", "null"]
          },
          "participantCount": {
            "type": "number"
          },
          "isParticipant": {
            "type": ["boolean", "null"]
          },
          "creator": {
            "$ref": "#/components/schemas/Creator"
          }
        },
        "required": [
          "id",
          "type",
          "title",
          "subtitle",
          "dateStart",
          "timeStart",
          "location",
          "participantCount",
          "creator"
        ]
      },
      "UpdateEvent": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "CYCLING",
              "KARONKKA",
              "MEETING",
              "NORDIC_WALKING",
              "ICE_HOCKEY",
              "ORIENTEERING",
              "OTHER",
              "RUNNING",
              "SKIING",
              "SPINNING",
              "SWIMMING",
              "TRACK_RUNNING",
              "TRAIL_RUNNING",
              "TRIATHLON",
              "ULTRAS"
            ],
            "example": "RUNNING"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "dateStart": {
            "type": "string",
            "format": "date"
          },
          "timeStart": {
            "type": "string"
          },
          "location": {
            "type": "string",
            "maxLength": 200
          },
          "subtitle": {
            "type": "string",
            "maxLength": 200
          },
          "description": {
            "type": "string"
          },
          "race": {
            "type": "boolean"
          }
        }
      },
      "SuccessMessage": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "required": ["message"]
      },
      "AdminUser": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "nickname": {
            "type": "string"
          },
          "picture": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["admin", "board_member", "member"]
          },
          "blocked": {
            "type": "boolean"
          },
          "lastLogin": {
            "type": ["string", "null"]
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "userId",
          "email",
          "name",
          "nickname",
          "picture",
          "role",
          "blocked",
          "lastLogin",
          "createdAt"
        ]
      },
      "AdminError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            },
            "required": ["code", "message"]
          }
        },
        "required": ["error"]
      },
      "UpdateRole": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": ["admin", "board_member", "member"]
          }
        },
        "required": ["role"]
      },
      "UpdateBlocked": {
        "type": "object",
        "properties": {
          "blocked": {
            "type": "boolean"
          }
        },
        "required": ["blocked"]
      },
      "FeeStatus": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "year": {
            "type": "string"
          },
          "paid": {
            "type": "boolean"
          }
        },
        "required": ["userId", "year", "paid"]
      },
      "UpdateFee": {
        "type": "object",
        "properties": {
          "paid": {
            "type": "boolean"
          }
        },
        "required": ["paid"]
      },
      "PaginatedEvents": {
        "type": "object",
        "properties": {
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdminEvent"
            }
          },
          "total": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "perPage": {
            "type": "number"
          }
        },
        "required": ["events", "total", "page", "perPage"]
      },
      "AdminEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "title": {
            "type": "string"
          },
          "dateStart": {
            "type": "string"
          },
          "timeStart": {
            "type": ["string", "null"]
          },
          "eventType": {
            "type": "string",
            "enum": [
              "CYCLING",
              "KARONKKA",
              "MEETING",
              "NORDIC_WALKING",
              "ICE_HOCKEY",
              "ORIENTEERING",
              "OTHER",
              "RUNNING",
              "SKIING",
              "SPINNING",
              "SWIMMING",
              "TRACK_RUNNING",
              "TRAIL_RUNNING",
              "TRIATHLON",
              "ULTRAS"
            ]
          },
          "location": {
            "type": ["string", "null"]
          },
          "race": {
            "type": "boolean"
          },
          "creatorNickname": {
            "type": "string"
          },
          "participantCount": {
            "type": "number"
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "dateStart",
          "timeStart",
          "eventType",
          "location",
          "race",
          "creatorNickname",
          "participantCount",
          "createdAt"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login with email and password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthError"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/signup": {
      "post": {
        "tags": ["Auth"],
        "summary": "Create a new user account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Signup successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Signup failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthError"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Request a password reset email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset email sent (always returns success)"
          }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Refresh an access token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token refreshed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RefreshResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid refresh token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthError"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout-url": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get Auth0 logout URL",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uri"
            },
            "required": true,
            "name": "returnTo",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Logout URL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogoutUrlResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current user profile",
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfile"
                }
              }
            }
          },
          "401": {
            "description": "Not authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthError"
                }
              }
            }
          }
        }
      }
    },
    "/api/events/{id}": {
      "get": {
        "tags": ["Events (Public)"],
        "summary": "Get event details (public)",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "42"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Event details with participants",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventDetail"
                }
              }
            }
          },
          "404": {
            "description": "Event not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Events"],
        "summary": "Update an event (owner only)",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "42"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateEvent"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          },
          "403": {
            "description": "Not the event owner",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Event not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Events"],
        "summary": "Delete an event (owner only)",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "42"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Event deleted"
          },
          "403": {
            "description": "Not the event owner",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Event not found",
            "content": {
              "application/json": {
                "schema": {
