{
  "name": "@dt65/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 4000",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "typegen": "varlock typegen && wrangler types",
    "test": "vitest run --config vitest.config.ts",
    "lint": "biome lint",
    "format": "biome check --write",
    "ci:lint": "biome ci",
    "generate-openapi": "varlock run -- tsx scripts/generate-openapi.ts",
    "clean": "rimraf dist",
    "db:create:users-seed": "varlock run -- tsx scripts/sync-auth0-users.ts",
    "db:local:seed-users": "wrangler d1 execute downtown65-db --local --file data/seed-users.sql",
    "db:local:migrate": "wrangler d1 migrations apply downtown65-db --local",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@dt65/shared": "workspace:*",
    "@hono/zod-openapi": "^1.2.2",
    "@scalar/hono-api-reference": "^0.10.3",
    "@varlock/infisical-plugin": "catalog:",
    "@varlock/cloudflare-integration": "catalog:",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "loglayer": "^9.1.0",
    "varlock": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:",
    "@cloudflare/vitest-pool-workers": "^0.12.1",
    "@vitest/coverage-v8": "catalog:",
    "drizzle-kit": "^0.31.10",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
