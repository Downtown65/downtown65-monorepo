{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "exclude": ["catalog"],
  "workspaces": {
    ".": {
      "ignoreDependencies": ["rimraf", "tsx"],
      "ignoreBinaries": ["wrangler"],
      "entry": [],
      "project": []
    },
    "apps/api": {
      "entry": ["src/index.ts", "vite.config.ts", "scripts/*.ts", "src/__tests__/**/*.ts"],
      "ignore": ["src/varlock-noop-patches.ts", "worker-configuration.d.ts"],
      "ignoreDependencies": ["@varlock/infisical-plugin", "@vitest/coverage-v8", "cloudflare"],
      "vite": false,
      "vitest": false
    },
    "apps/events": {
      "entry": ["app/routes/**/*.{ts,tsx}", "app/lib/*.ts", "workers/app.ts"],
      "project": ["app/**/*.{ts,tsx}", "workers/**/*.ts"],
      "ignoreDependencies": ["@varlock/infisical-plugin", "@vitest/coverage-v8"],
      "vite": false,
      "vitest": false
    },
    "apps/www": {
      "entry": ["src/pages/**/*.astro"],
      "ignoreDependencies": ["@vitest/coverage-v8", "wrangler"]
    },
    "packages/shared": {}
  }
}
