{
  "name": "@dt65/root",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "typegen": "pnpm -r run typegen",
    "generate-openapi": "pnpm -r run generate-openapi",
    "check": "pnpm -r run ci:lint && pnpm knip && sherif",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "ci:lint": "pnpm -r run ci:lint",
    "typecheck": "tsc --build",
    "test": "pnpm -r run test",
    "clean": "pnpm -r run clean"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "sharp",
      "workerd"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/node": "^25.0.3",
    "knip": "^5.83.0",
    "lefthook": "latest",
    "rimraf": "catalog:",
    "sherif": "^1.10.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
